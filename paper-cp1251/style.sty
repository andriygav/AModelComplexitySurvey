\newcounter{authors}
\newcommand{\@authlist}{}
\newcommand{\@authors}{}
\newcommand{\@affillist}{}

\newcommand{\clearauthors}{
\global\let\@title\@empty
\global\let\@authlist\@empty
\global\let\@authors\@empty
\global\let\@affillist\@empty
\global\let\UDK\@empty
\setcounter{authors}{0}}

\renewcommand\author[3][\@empty]{%
\ifx\@empty #1
  \def\@note{}
\else
  \def\@note{$^{#1}$}
\fi
\addtocounter{authors}{1}%
\ifnum\value{authors}>1
  \def\@sep{, }
\else
  \def\@sep{}
  \gdef\@firstauthor{#2}
\fi
\begingroup
  \let\protect\@unexpandable@protect
  \edef\@itema{\@sep#2~#3\@note}
  \@temptokena=\expandafter{\@authlist}%
  \xdef\@authlist{\the\@temptokena\@itema}
  \edef\@itemb{\@sep#3~#2}
  \@temptokena=\expandafter{\@authors}%
  \xdef\@authors{\the\@temptokena\@itemb}
\endgroup}

\newcommand\affil[2][\@empty]{%
\ifx\@empty #1
  \def\@note{}
\else
  \def\@note{$^{#1}$}
\fi
\xdef\@affillist{\@affillist\par\@note #2}}

\renewcommand{\@author}{\@authlist}
\newcommand{\@affil}{\@affillist}

\renewcommand{\maketitle}{%
\parbox{0.9\textwidth}{\centering
{\itshape\@authlist\par}
\medskip
{\footnotesize\@affillist\par}
\par\medskip
{\Large\bfseries\@title\par}}
\medskip
\clearauthors}

